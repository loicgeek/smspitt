{
  "name": "smspitt",
  "version": "0.1.0",
  "description": "SMS Mock Server — intercept, inspect and simulate SMS messages. The Mailpit for SMS.",
  "type": "module",
  "bin": {
    "smspitt": "./bin/smspitt.js"
  },
  "exports": "./src/index.js",
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node bin/smspitt.js",
    "dev": "node bin/smspitt.js --verbose",
    "start:sqlite": "node bin/smspitt.js --storage=sqlite",
    "start:ci": "node bin/smspitt.js --no-ui --no-open"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "minimist": "^1.2.8"
  },
  "keywords": [
    "sms",
    "mock",
    "testing",
    "twilio",
    "orange",
    "vonage",
    "africastalking",
    "mailpit",
    "development",
    "local"
  ],
  "author": {
    "name": "NtechServices",
    "url": "https://github.com/loicgeek"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loicgeek/smspitt.git"
  },
  "homepage": "https://github.com/loicgeek/smspitt#readme",
  "bugs": {
    "url": "https://github.com/loicgeek/smspitt/issues"
  }
}
